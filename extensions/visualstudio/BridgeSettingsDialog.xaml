<Window x:Class="ContextToAgent.BridgeSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ContextToAgent"
        Title="ContextToAgent" Height="420" Width="720"
        WindowStartupLocation="CenterOwner">
  <DockPanel>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0,12,12">
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <local:BridgeSettingsControl x:Name="SettingsControl" />
  </DockPanel>
</Window>
