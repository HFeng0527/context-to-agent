<Window x:Class="ContextToAgent2026.BridgeSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Context To Agent" Height="360" Width="640"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="16">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
    <StackPanel><TextBlock Text="Context To Agent" FontSize="20" FontWeight="SemiBold" /><TextBlock x:Name="StatusText" Margin="0,8,0,12" /></StackPanel>
    <Grid Grid.Row="1">
      <Grid.RowDefinitions><RowDefinition Height="2*" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
      <DataGrid x:Name="AgentGrid" AutoGenerateColumns="False" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Agent" Binding="{Binding Name}" Width="160" />
          <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="90" />
          <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
          <DataGridTextColumn Header="Config Path" Binding="{Binding ConfigPath}" Width="*" />
        </DataGrid.Columns>
      </DataGrid>
      <TextBlock Grid.Row="1" Text="Recent reads" FontWeight="SemiBold" Margin="0,12,0,4" />
      <ListBox x:Name="RecentReadsList" Grid.Row="2" />
    </Grid>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Start Bridge" Width="110" Margin="0,0,8,0" Click="StartBridge_Click" />
      <Button Content="Configure All" Width="110" Margin="0,0,8,0" Click="ConfigureAll_Click" />
      <Button Content="Configure Other Agents" Width="160" Margin="0,0,8,0" Click="ConfigureOtherAgents_Click" />
      <Button Content="Revoke All" Width="90" Margin="0,0,8,0" Click="RevokeAll_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
  </Grid>
</Window>
